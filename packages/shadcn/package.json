{
  "name": "@kumix/shadcn",
  "version": "0.1.0",
  "description": "Headless, accessible React component library built on Base UI, Tailwind, and more.",
  "author": "Kumix Labs <hai@kumix.io>",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./css": {
      "types": "./dist/style.css.d.ts",
      "default": "./dist/style.css"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "clean:all": "rimraf .turbo coverage dist node_modules",
    "dev": "tsdown --watch",
    "build:css": "cp src/style.css dist/style.css && cp src/style.css.d.ts dist/style.css.d.ts",
    "build": "rimraf dist && mkdir -p dist && bun run build:css && tsdown && publint",
    "types:check": "tsc --noEmit"
  },
  "homepage": "https://github.com/kumixlabs/ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kumixlabs/ui.git",
    "directory": "packages/shadcn"
  },
  "bugs": {
    "url": "https://github.com/kumixlabs/ui/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kumix",
    "shadcn",
    "components",
    "tailwind",
    "react",
    "ui"
  ],
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@kumix/tsconfig": "^0.1.0",
    "@kumix/utils": "^0.1.2",
    "@shadcn/react": "^0.2.1",
    "@types/react": "^19.2.17",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.25.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.10.0",
    "sonner": "^2.0.7",
    "tsdown": "^0.22.12",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@base-ui/react": ">=1.6.0",
    "@kumix/utils": ">=0.1.0",
    "@shadcn/react": ">=0.2.0",
    "class-variance-authority": ">=0.7.0",
    "cmdk": ">=1.1.0",
    "embla-carousel-react": ">=8.6.0",
    "input-otp": ">=1.4.0",
    "lucide-react": ">=1.24.0",
    "next-themes": ">=0.4.6",
    "react": ">=18.0.0 || >=19.0.0-rc.0",
    "react-day-picker": ">=10.0.0",
    "react-resizable-panels": ">=4.12.0",
    "recharts": ">=3.8.0",
    "sonner": ">=2.0.7"
  },
  "peerDependenciesMeta": {
    "@shadcn/react": {
      "optional": true
    },
    "cmdk": {
      "optional": true
    },
    "embla-carousel-react": {
      "optional": true
    },
    "input-otp": {
      "optional": true
    },
    "next-themes": {
      "optional": true
    },
    "react-day-picker": {
      "optional": true
    },
    "react-resizable-panels": {
      "optional": true
    },
    "recharts": {
      "optional": true
    },
    "sonner": {
      "optional": true
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
