{
  "name": "@kumix/ui",
  "version": "0.2.0",
  "description": "Kumix React UI kit: shadcn/ui (Base UI, base-nova) + ReUI components, Tailwind tokens, and hooks. Per-file ESM exports.",
  "author": "Kumix Labs <hai@kumix.io>",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./css": {
      "types": "./dist/style.css.d.ts",
      "default": "./dist/style.css"
    },
    "./theme": {
      "types": "./dist/theme.css.d.ts",
      "default": "./dist/theme.css"
    },
    "./*": {
      "types": "./dist/components/*.d.ts",
      "default": "./dist/components/*.js"
    },
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "default": "./dist/hooks/*.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "clean:all": "rimraf .turbo dist node_modules",
    "dev": "tsdown --watch",
    "build:css": "cp src/style.css dist/style.css && cp src/theme.css dist/theme.css && cp src/style.css.d.ts dist/style.css.d.ts && cp src/theme.css.d.ts dist/theme.css.d.ts",
    "build": "rimraf dist && mkdir -p dist && bun run build:css && tsdown && publint",
    "types:check": "tsc --noEmit",
    "add:shadcn": "shadcn add --all --overwrite",
    "add:reui": "shadcn add @reui/alert @reui/autocomplete @reui/badge @reui/data-grid @reui/date-selector @reui/event-calendar @reui/use-file-upload @reui/filters @reui/frame @reui/gantt @reui/icon-stack @reui/kanban @reui/number-field @reui/phone-input @reui/rating @reui/scrollspy @reui/sortable @reui/stepper @reui/timeline @reui/tree --overwrite"
  },
  "homepage": "https://github.com/kumixlabs/ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kumixlabs/ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/kumixlabs/ui/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kumix",
    "react",
    "ui",
    "components",
    "shadcn",
    "reui",
    "base-ui",
    "tailwind",
    "tailwindcss",
    "hooks"
  ],
  "dependencies": {
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.6.0",
    "@date-fns/tz": "^1.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headless-tree/core": "^1.7.0",
    "@kumix/tsconfig": "^0.1.0",
    "@kumix/utils": "^0.1.2",
    "@shadcn/react": "^0.2.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.8",
    "@types/react": "^19.2.17",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.25.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.8",
    "react-day-picker": "^10.0.1",
    "react-phone-number-input": "^3.4.17",
    "react-resizable-panels": "^4.12.2",
    "recharts": "3.10.0",
    "sonner": "^2.0.7",
    "tsdown": "^0.22.13",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@base-ui/react": ">=1.6.0",
    "@date-fns/tz": ">=1.5.0",
    "@dnd-kit/core": ">=6.3.0",
    "@dnd-kit/modifiers": ">=9.0.0",
    "@dnd-kit/sortable": ">=10.0.0",
    "@dnd-kit/utilities": ">=3.2.0",
    "@headless-tree/core": ">=1.7.0",
    "@kumix/utils": ">=0.1.0",
