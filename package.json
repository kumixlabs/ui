{
  "name": "root",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "clean": "turbo run clean",
    "clean:all": "turbo run clean:all && rm -rf .turbo bun.lock .husky/_ node_modules",
    "prepare": "husky",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "biome check",
    "lint:fix": "biome check --write --unsafe",
    "format": "biome format --write",
    "format:check": "biome format",
    "types:check": "turbo run types:check",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "version": "changeset version && bun update",
    "release": "bash ./scripts/publish.sh"
  },
  "keywords": [],
  "author": "Kumix Labs <hai@kumix.io>",
  "license": "MIT",
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@biomejs/biome": "^2.5.3",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@kumix/biome-config": "^0.1.0",
    "@testing-library/react": "^16.3.2",
    "@tsdown/css": "^0.22.7",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "react-dom": "^19.2.7",
    "rimraf": "^6.1.3",
    "turbo": "^2.10.4",
    "typescript": "catalog:",
    "vitest": "^4.1.10"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "apps/*"
    ],
    "catalog": {
      "@kumix/tsconfig": "0.1.0",
      "tsdown": "0.22.4",
      "typescript": "6.0.3"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}": "biome check --write --no-errors-on-unmatched",
    "*.{md,yml,yaml}": "prettier --write",
    "*.{json,jsonc,html}": "biome format --write --no-errors-on-unmatched"
  },
  "engines": {
    "node": ">=24",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14"
}
